---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import site from "../content/site.json";

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/https://pitfielddigital.github.io/348-ilkeston-air-cadets/icons/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Commissioner:wght@100..900&family=Josefin+Sans:ital,wght@0,100..700;1,100..700&display=swap" rel="stylesheet">
    <title>{title ? `${title} | ${site.siteName}` : site.siteName}</title>
</head>
<body>
    <Header />
    <main>
        <slot />
    </main>
    <Footer />
    <script src="/scripts/global.js" defer></script>
</body>
</html>